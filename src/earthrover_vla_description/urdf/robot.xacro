<?xml version="1.0" encoding="UTF-8"?>
<!-- This file defines the robot geometry and joints -->

<robot name="earthrover_vla" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Geometry and Constants-->
    <xacro:property name="pi_const" value="3.14159265" />

    <!-- Body Dimensions -->
    <xacro:property name="a" value="0.250"/> <!-- Uses default gazebo units, m)-->
    <xacro:property name="b" value="0.160"/>
    <xacro:property name="c" value="0.150"/>

    <!-- Wheel Dimensions -->
    <!-- Wheel radius-->
    <xacro:property name="r" value="0.035" />
    <!-- wheel width -->
    <xacro:property name="d" value="0.05" />
    

    <xacro:property name="s1" value="${b/2+r}"/>
    <xacro:property name="s2" value="${2*r}"/>
    <xacro:property name="s3" value="${2*r}"/>
    <xacro:property name="s4" value="${c/2 + d/2}"/>


    <!-- Mass and Inertia -->
    <!-- Material Densities-->
    <!-- Body Material Density -->
    <xacro:property name="d1" value="2710.0"/>
    <!-- Wheel Material density-->
    <xacro:property name="d2" value="2710.0" />
    
    <!-- Robot body mass, wheel mass -->
    <!-- body-->
    <xacro:property name="m1" value="${d1*a*b*c}" />
    <!-- wheel -->
    <xacro:property name="m2" value="${d2*pi_const*r*r*d}" />

    <!-- Moments of intertia of the robot body-->
    <xacro:property name="Ix_body" value="${(1/12)*m1*(b*b+c*c) }" />
    <xacro:property name="Iy_body" value="${(1/12)*m1*(b*b+a*a) }" />
    <xacro:property name="Iz_body" value="${(1/12)*m1*(a*a+c*c) }"/>

    <!-- Moments of intertia of the wheel-->
    <xacro:property name="I_wheel" value="${0.5*m2*r*r}" />
    <xacro:property name="Iz_wheel" value="${(1.0/ 12.0)*m2*(3.0*r*r+d*d) }"/>

    <!-- Macro for the inertial section of the body -->
    <xacro:macro name="inertia_body">
        <inertial>
            <!-- Displacement and orientation of COM of the frame of link WRT to parent frame-->
             <origin rpy="0 0 0" xyz="0 0 ${s1}" /> <!-- roll, pitch and yaw + xyz disiplacement between parent frame to COM-->
             <mass value="${m1}"/>
             <inertia ixx="${Ix_body}" ixy="0.0" ixz="0.0" iyy="${Iy_body}" iyz="0.0" izz="${Iz_body}"/>
        </inertial>
    </xacro:macro>

    <!-- Macro for the inertial section of the wheel -->
     <xacro:macro name="inertia_wheel">
        <inertial>
            <origin rpy="1.570795 0.0 0.0" xyz="0.0 0.0 0.0"/>
            <mass value="${m2}"/>
            <inertia ixx="${I_wheel}" ixy="0.0" ixz="0.0" iyy="${I_wheel}" iyz="0.0" izz="${Iz_wheel}"/>
        </inertial>
     </xacro:macro>

        <!-- Camera Dimensions and Properties -->
    <!-- Dimensions -->
    <xacro:property name="cam_y" value="0.06" />
    <xacro:property name="cam_z" value="0.05" />
    <xacro:property name="cam_x" value="0.03" />
    <!-- Mass-->
    <xacro:property name="cam_mass" value="${cam_y*cam_z*cam_x*d1}" />
    
    <!-- Moments of inertia -->
    <xacro:property name="Ix_cam" value="${(1/12)*cam_mass*(cam_y*cam_y+cam_z*cam_z)}" />
    <xacro:property name="Iy_cam" value="${(1/12)*cam_mass*(cam_x*cam_x+cam_z*cam_z)}" />
    <xacro:property name="Iz_cam" value="${(1/12)*cam_mass*(cam_x*cam_x+cam_y*cam_y)}" />
    
    <!-- Macro for inertia -->
    <xacro:macro name="inertia_cam">
        <inertial>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <mass value="${cam_mass}"/>
            <inertia ixx="${Ix_cam}" ixy="0.0" ixz="0.0" iyy="${Iy_cam}" iyz="0.0" izz="${Iz_cam}"/>
        </inertial>
    </xacro:macro>


    <!-- Define Links and Joints-->
    
    <!-- Base Footprint (fictitious link for fixing coordinate systems to the ground-->
    <link name="base_footprint"> </link>
    <joint name="body_link_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="body_link"/>
    </joint>

    <!-- Body link-->
    <link name="body_link">
        <visual>
            <geometry>
                <box size="${a} ${c} ${b}"/>
            </geometry>
        <origin xyz="0.0 0.0 ${s1}" rpy="0.0 0.0 0.0"/>
        </visual>

        <collision>
            <geometry>
                <box size="${a} ${c} ${b}"/>
            </geometry>
            <origin xyz="0.0 0.0 ${s1}" rpy="0.0 0.0 0.0"/>
        </collision>

        <xacro:inertia_body />
    </link>

    <!-- Back right wheel of robot and joint -->
    <joint name="wheel1_joint" type="continuous">
        <origin xyz="${-s2} ${-s4} ${r}" rpy="0.0 0.0 0.0"/> <!-- Defined wrt to the frame of the parent link-->
        <parent link="body_link"/>
        <child link="wheel1_link"/>
        <axis xyz="0 1 0"/>
        <limit effort="50000.0" velocity="10.0"/> <!-- Max torque and velocity -->
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name="wheel1_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/> <!-- Relative to the frame attached to the wheel1_joint-->
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </collision>

        <xacro:inertia_wheel/>

    </link>

    <!-- Back left wheel of robot and joint-->
     <joint name="wheel2_joint" type="continuous">
        <origin xyz="${-s2} ${s4} ${r}" rpy="0.0 0.0 0.0"/>
        <parent link="body_link"/>
        <child link="wheel2_link"/>
        <axis xyz="0.0 1 0.0"/>
        <limit effort="50000.0" velocity="10.0"/>
        <dynamics damping="1.0" friction="1.0"/>
     </joint>
    
     
    <link name="wheel2_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/> <!-- Relative to the frame attached to the wheel1_joint-->
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </collision>

        <xacro:inertia_wheel/>

    </link>

    <!-- Front right wheel of robot and joint -->
    <joint name="wheel3_joint" type="continuous">
        <origin xyz="${s2} ${-s4} ${r}" rpy="0.0 0.0 0.0"/> <!-- Defined wrt to the frame of the parent link-->
        <parent link="body_link"/>
        <child link="wheel3_link"/>
        <axis xyz="0 1 0"/>
        <limit effort="50000.0" velocity="10.0"/> <!-- Max torque and velocity -->
        <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name="wheel3_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/> <!-- Relative to the frame attached to the wheel1_joint-->
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </collision>

        <xacro:inertia_wheel/>

    </link>

    <!-- Front left wheel of robot and joint-->
     <joint name="wheel4_joint" type="continuous">
        <origin xyz="${s2} ${s4} ${r}" rpy="0.0 0.0 0.0"/>
        <parent link="body_link"/>
        <child link="wheel4_link"/>
        <axis xyz="0.0 1 0.0"/>
        <limit effort="50000.0" velocity="10.0"/>
        <dynamics damping="1.0" friction="1.0"/>
     </joint>
    
     
    <link name="wheel4_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/> <!-- Relative to the frame attached to the wheel1_joint-->
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.570795 0.0 0.0"/>
            <geometry>
                <cylinder radius="${r}" length="${d}"/>
            </geometry>
        </collision>

        <xacro:inertia_wheel/>

    </link>

    <!-- Camera link and joint -->
     <joint name="cam_joint" type="fixed">
        <origin xyz="${a/2} 0.0 ${s1}" rpy="0.0 0.0 0.0"/>
        <parent link="body_link"/>
        <child link="cam_link"/>        
     </joint>

     <link name="cam_link">
        <visual>
            <geometry>
                <box size="${cam_x} ${cam_y} ${cam_z}"/>
            </geometry>
            <origin xyz="${cam_x/2} 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </visual>

        <collision>
           <geometry>
                <box size="${cam_x} ${cam_y} ${cam_z}"/>
            </geometry>
            <origin xyz="${cam_x/2} 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </collision>

        <xacro:inertia_cam/>
        
     </link>

          <joint name="cam_optical_joint" type="fixed">
        <!-- Rotate coordinate system to allow optical coordinates -->
        <origin xyz="0.0 0.0 0.0" rpy="${-pi_const/2} 0.0 ${-pi_const/2}"/> 
        <parent link="cam_link"/>
        <child link="cam_link_optical"/>        
     </joint>

     <link name="cam_link_optical"></link>
    
</robot>
